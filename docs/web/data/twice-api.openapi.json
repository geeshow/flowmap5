{
  "openapi" : "3.1.0",
  "info" : {
    "title" : "twice-api",
    "version" : "1.0.0"
  },
  "tags" : [ {
    "name" : "twice-api"
  } ],
  "paths" : {
    "/internal/user/for-login" : {
      "post" : {
        "operationId" : "com.acme.twice.TwiceUserController#getForLogin",
        "tags" : [ "twice-api" ],
        "summary" : "트와이스 로그인용 사용자 조회",
        "requestBody" : {
          "required" : true,
          "content" : {
            "application/json" : {
              "schema" : {
                "type" : "object",
                "additionalProperties" : {
                  "type" : "string"
                }
              },
              "example" : "{\"userId\":\"u-42\"}"
            }
          }
        },
        "responses" : {
          "200" : {
            "description" : "트와이스 로그인용 사용자 조회",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/UserView"
                },
                "example" : "{\"id\":\"u-42\",\"token\":\"token-u-42\"}"
              }
            }
          }
        }
      }
    },
    "/internal/user/for-refresh" : {
      "get" : {
        "operationId" : "com.acme.twice.TwiceUserController#getForTokenRefresh",
        "tags" : [ "twice-api" ],
        "summary" : "토큰 리프레시용 사용자 조회",
        "parameters" : [ {
          "name" : "userId",
          "in" : "query",
          "required" : true,
          "schema" : {
            "type" : "string"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "토큰 리프레시용 사용자 조회",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/UserView"
                }
              }
            }
          }
        }
      }
    }
  },
  "components" : {
    "schemas" : {
      "UserView" : {
        "type" : "object",
        "properties" : {
          "id" : {
            "type" : "string"
          },
          "token" : {
            "type" : "string"
          }
        },
        "required" : [ "id", "token" ]
      }
    }
  }
}